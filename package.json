{
  "dependencies": {
    "@dagrejs/graphlib": "^4.0.1",
    "@kubernetes/client-node": "^1.4.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "execa": "^9.5.2",
    "git-url-parse": "^16.1.0",
    "gray-matter": "^4.0.3",
    "ky": "^2.0.2",
    "micromatch": "^4.0.8",
    "p-limit": "^7.3.0",
    "package-manager-detector": "^1.6.0",
    "secure-json-parse": "^4.1.0",
    "simple-git": "^3.36.0",
    "zod": "^4.4.3",
    "xstate": "^5.31.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.9.1",
    "jscpd": "^4.0.5",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "ultracite": "7.7.0",
    "vitest": "^3.2.0"
  },
  "name": "@oisincoveney/pipeline",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oisin-ee/pipeline-runner.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "moka": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./argo-workflow": {
      "types": "./dist/argo-workflow.d.ts",
      "import": "./dist/argo-workflow.js"
    },
    "./argo-submit": {
      "types": "./dist/argo-submit.d.ts",
      "import": "./dist/argo-submit.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./planner": {
      "types": "./dist/workflow-planner.d.ts",
      "import": "./dist/workflow-planner.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js"
    },
    "./runner-command-contract": {
      "types": "./dist/runner-command-contract.d.ts",
      "import": "./dist/runner-command-contract.js"
    },
    "./runtime/goal-loop": {
      "types": "./dist/runtime/goal-loop.d.ts",
      "import": "./dist/runtime/goal-loop.js"
    },
    "./runtime/goal-state": {
      "types": "./dist/runtime/goal-state.d.ts",
      "import": "./dist/runtime/goal-state.js"
    },
    "./runtime": {
      "types": "./dist/pipeline-runtime.d.ts",
      "import": "./dist/pipeline-runtime.js"
    },
    "./schedule": {
      "types": "./dist/schedule-planner.d.ts",
      "import": "./dist/schedule-planner.js"
    }
  },
  "files": [
    ".agents/skills",
    ".pipeline/skills",
    "defaults",
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build:cli": "tsdown",
    "test": "vitest run",
    "test:image": "mkdir -p /tmp/pipeline-test && printf '{}' > /tmp/pipeline-test/payload.json && printf 'kind: pipeline-schedule\\nversion: 1\\nschedule_id: smoke\\ngenerated_at: 2026-06-10T00:00:00.000Z\\nsource_entrypoint: custom\\ntask: smoke\\nroot_workflow: root\\nworkflows:\\n  root:\\n    nodes:\\n      - id: smoke\\n        kind: command\\n        command: [true]\\n' > /tmp/pipeline-test/schedule.yaml && printf '{\"nodeId\":\"smoke\"}' > /tmp/pipeline-test/task.json && printf 'test-token' > /tmp/pipeline-test/event-token && docker build -t pipeline-runner:test . && docker run --rm -v /tmp/pipeline-test/payload.json:/etc/pipeline/payload.json:ro -v /tmp/pipeline-test/schedule.yaml:/etc/pipeline/schedule.yaml:ro -v /tmp/pipeline-test/task.json:/etc/pipeline/task.json:ro -v /tmp/pipeline-test/event-token:/etc/pipeline/event-auth/token:ro pipeline-runner:test runner-command --payload-file /etc/pipeline/payload.json --schedule-file /etc/pipeline/schedule.yaml; test $? -eq 64",
    "test:dogfood": "vitest run tests/dogfood-installed.test.ts",
    "test:live-runners": "PIPELINE_LIVE_RUNNERS=1 vitest run tests/dogfood-live-runners.test.ts",
    "typecheck": "tsc --noEmit",
    "build": "bun run build:cli",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepack": "bun run build:cli"
  },
  "type": "module",
  "version": "1.5.6",
  "description": "Config-driven multi-agent pipeline runner for repository work",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=22.13.0",
    "bun": ">=1.1.0"
  }
}
