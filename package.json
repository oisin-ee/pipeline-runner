{
  "name": "@oisincoveney/pipeline",
  "version": "0.0.0-development",
  "description": "Config-driven multi-agent pipeline runner for repository work",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oisin-ee/pipeline-runner.git"
  },
  "bin": {
    "moka": "dist/index.js"
  },
  "files": [
    "defaults",
    "dist",
    "docs",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./argo-workflow": {
      "types": "./dist/argo-workflow.d.ts",
      "import": "./dist/argo-workflow.js"
    },
    "./argo-submit": {
      "types": "./dist/argo-submit.d.ts",
      "import": "./dist/argo-submit.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./factory-lane": {
      "types": "./dist/factory-lane.d.ts",
      "import": "./dist/factory-lane.js"
    },
    "./events": {
      "types": "./dist/runner-event-schema.d.ts",
      "import": "./dist/runner-event-schema.js"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.js"
    },
    "./moka-submit": {
      "types": "./dist/moka-submit.d.ts",
      "import": "./dist/moka-submit.js"
    },
    "./moka-global-config": {
      "types": "./dist/moka-global-config.d.ts",
      "import": "./dist/moka-global-config.js"
    },
    "./planner": {
      "types": "./dist/planning/compile.d.ts",
      "import": "./dist/planning/compile.js"
    },
    "./runner": {
      "types": "./dist/runner.d.ts",
      "import": "./dist/runner.js"
    },
    "./runner-command-contract": {
      "types": "./dist/runner-command-contract.d.ts",
      "import": "./dist/runner-command-contract.js"
    },
    "./tickets": {
      "types": "./dist/tickets/ticket-graph-dto.d.ts",
      "import": "./dist/tickets/ticket-graph-dto.js"
    },
    "./runtime": {
      "types": "./dist/pipeline-runtime.d.ts",
      "import": "./dist/pipeline-runtime.js"
    },
    "./schedule": {
      "types": "./dist/planning/generate.d.ts",
      "import": "./dist/planning/generate.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:cli": "tsdown",
    "test": "vitest run",
    "test:image": "mkdir -p /tmp/pipeline-test && printf '{}' > /tmp/pipeline-test/payload.json && printf 'kind: pipeline-schedule\\nversion: 1\\nschedule_id: smoke\\ngenerated_at: 2026-06-10T00:00:00.000Z\\nsource_entrypoint: custom\\ntask: smoke\\nroot_workflow: root\\nworkflows:\\n  root:\\n    nodes:\\n      - id: smoke\\n        kind: command\\n        command: [true]\\n' > /tmp/pipeline-test/schedule.yaml && printf '{\"nodeId\":\"smoke\"}' > /tmp/pipeline-test/task.json && printf 'test-token' > /tmp/pipeline-test/event-token && docker build -t pipeline-runner:test . && docker run --rm -v /tmp/pipeline-test/payload.json:/etc/pipeline/payload.json:ro -v /tmp/pipeline-test/schedule.yaml:/etc/pipeline/schedule.yaml:ro -v /tmp/pipeline-test/task.json:/etc/pipeline/task.json:ro -v /tmp/pipeline-test/event-token:/etc/pipeline/event-auth/token:ro pipeline-runner:test runner-command --payload-file /etc/pipeline/payload.json --schedule-file /etc/pipeline/schedule.yaml; test $? -eq 64",
    "test:dogfood": "vitest run tests/dogfood-installed.test.ts",
    "test:live-runners": "PIPELINE_LIVE_RUNNERS=1 vitest run tests/dogfood-live-runners.test.ts",
    "local-orbstack:migrate": "nub scripts/local-orbstack/migrate-postgres.ts",
    "typecheck": "tsc --noEmit",
    "build": "nub run build:cli",
    "check": "ultracite check --type-aware",
    "fix": "ultracite fix",
    "prepack": "nub run build:cli"
  },
  "dependencies": {
    "@dagrejs/graphlib": "^4.0.1",
    "@kubernetes/client-node": "^1.4.0",
    "@opencode-ai/sdk": "1.17.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "commander": "^14.0.3",
    "drizzle-orm": "0.45.2",
    "effect": "4.0.0-beta.92",
    "execa": "^9.5.2",
    "git-url-parse": "^16.1.0",
    "graphology": "0.26.0",
    "graphology-metrics": "2.4.0",
    "graphology-types": "0.24.8",
    "gray-matter": "^4.0.3",
    "js-tiktoken": "^1.0.21",
    "jsonc-parser": "^3.3.1",
    "ky": "^2.0.2",
    "micromatch": "^4.0.8",
    "package-manager-detector": "^1.6.0",
    "pino": "^10.3.1",
    "postgres": "3.4.9",
    "secure-json-parse": "^4.1.0",
    "simple-git": "^3.36.0",
    "tree-sitter-javascript": "0.25.0",
    "tree-sitter-typescript": "0.23.2",
    "web-tree-sitter": "0.26.9",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@effect/vitest": "^4.0.0-beta.90",
    "@mpsuesser/oxlint-plugin-effect": "0.3.0",
    "@oisin-ee/oxlint-config": "1.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/micromatch": "^4.0.10",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260629.1",
    "drizzle-kit": "0.31.10",
    "jscpd": "^4.0.5",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.22.0",
    "typescript": "rc",
    "ultracite": "7.7.0",
    "vitest": "^3.2.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "nub",
      "version": "^0.2.7",
      "onFail": "warn"
    }
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "nub@0.2.7",
  "allowBuilds": {
    "tree-sitter-typescript": false,
    "msgpackr-extract": false
  }
}
