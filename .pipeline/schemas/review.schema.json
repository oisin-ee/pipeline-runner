{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string"
          },
          "line": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "message": {
            "type": "string"
          },
          "rule": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["info", "warn", "error", "critical"]
          }
        },
        "required": ["message", "severity"],
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    }
  },
  "required": ["findings", "verdict"],
  "additionalProperties": false
}
