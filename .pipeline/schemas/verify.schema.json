{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["evidence", "verdict"],
  "additionalProperties": false
}
