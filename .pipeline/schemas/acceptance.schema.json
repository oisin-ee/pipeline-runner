{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "acceptance": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "id": {
            "type": "string"
          },
          "verdict": {
            "type": "string",
            "enum": ["PASS", "FAIL"]
          }
        },
        "required": ["evidence", "id", "verdict"],
        "additionalProperties": false
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["PASS", "FAIL"]
    },
    "violations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["acceptance", "evidence", "verdict"],
  "additionalProperties": false
}
