{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "changes": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "files": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "why": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["files", "summary", "why"],
        "additionalProperties": false
      }
    },
    "followups": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "lessons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "string"
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["changes", "verification"],
  "additionalProperties": false
}
