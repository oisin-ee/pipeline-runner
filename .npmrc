node-linker=hoisted
# effect v4 is on a beta pilot. nub's default trust-policy (no-downgrade) refuses
# these: the prior 3.x releases carried a trusted-publisher attestation, but the
# 4.0.0-beta.90 releases ship only provenance attestation, which nub reads as a
# trust downgrade (ERR_NUB_TRUST_DOWNGRADE). Exclude the exact pinned beta
# versions (nub rejects name-glob+version) so the pilot installs without
# weakening the trust policy globally.
trust-policy-exclude=["effect@4.0.0-beta.90","@effect/vitest@4.0.0-beta.90"]
