{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "pipeline-gateway": {
      "enabled": true,
      "headers": {
        "Authorization": "{env:PIPELINE_MCP_GATEWAY_AUTHORIZATION}"
      },
      "oauth": false,
      "type": "remote",
      "url": "http://127.0.0.1:4483/mcp"
    }
  },
  "lsp": true,
  "plugin": ["@devtheops/opencode-plugin-otel@1.1.0"]
}
